# Frontend Environment Variables (Expo)
# In Expo SDK 49+, variables prefixed with EXPO_PUBLIC_ are automatically exposed to client-side code.

# The base URL of the backend API.
# - For local development on web/iOS Simulator, you can use: http://localhost:5000
# - For Android Emulator, you can use: http://10.0.2.2:5000
# - For physical mobile devices, you can set this to your computer's local IP: http://<your-local-ip>:5000
# - If left empty or unset, the app will dynamically resolve your machine's IP (via Expo hostUri) during local development.
EXPO_PUBLIC_API_URL=http://localhost:5000
