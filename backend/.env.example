# Backend Environment Variables

# The port the server should run on
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/aimclasses

# JWT Secrets for token generation and validation
JWT_ACCESS_SECRET=your_jwt_access_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here

# Token expiration times
ACCESS_TOKEN_EXPIRE=1d
REFRESH_TOKEN_EXPIRE=30d

# Comma-separated list of admin mobile numbers (with country code, e.g. +919999999999)
ADMIN_MOBILES=+919999999999

# Google service account email for Drive access
GOOGLE_CLIENT_EMAIL=your_service_account_email@your_project.iam.gserviceaccount.com

# Google service account private key (with escaped newlines \n)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# Google Drive parent folder ID where courses and chapters will be created
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Google OAuth2 Client Credentials (alternative/preferred for high-volume storage)
GOOGLE_CLIENT_ID=your_oauth2_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_oauth2_client_secret
GOOGLE_REFRESH_TOKEN=your_oauth2_refresh_token

# Master password for admin login
ADMIN_PASS=admin123

# Toggle student free trial mode (true = students see all courses, false = only assigned courses)
FREE_TRIAL_MODE=true
