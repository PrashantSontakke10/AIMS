                  "pm.test(\"Notes array is returned and stored\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.be.an(\"array\");",
                  "    pm.expect(response.length).to.be.greaterThan(0);",
                  "    const firstNote = response[0];",
                  "    pm.expect(firstNote).to.have.property(\"_id\");",
                  "    pm.expect(firstNote).to.have.property(\"fileId\");",
                  "    pm.expect(firstNote.chapter).to.equal(pm.collectionVariables.get(\"lastChapterId\"));",
                  "    if (firstNote._id) {",
