  "info": {
    "_postman_id": "848bb247-fdb9-4674-8848-bc6b5a3bbf40",
    "name": "AimClasses API with Automated Tests",
    "description": "Postman Collection for all AimClasses Backend APIs (Auth, Admin, Courses, Chapters, Lectures, and Notes) equipped with automated integration test assertions and dynamic variable chaining.",
