  "item": [
    {
      "name": "1. Authentication",
      "description": "Endpoints relating to authentication (Login, Token Refresh, and Logout)",
      "item": [
        {
          "name": "Login or Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response has success message\", function () {",
                  "    pm.expect(pm.response.json().message).to.include(\"successful\");",
                  "});",
                  "pm.test(\"Tokens are returned and stored\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property(\"accessToken\");",
                  "    pm.expect(response).to.have.property(\"refreshToken\");",
                  "    if (response.accessToken) {",
                  "        pm.collectionVariables.set(\"accessToken\", response.accessToken);",
                  "    }",
                  "    if (response.refreshToken) {",
                  "        pm.collectionVariables.set(\"refreshToken\", response.refreshToken);",
                  "    }",
                  "    if (response.user && response.user.id) {",
                  "        pm.collectionVariables.set(\"studentUserId\", response.user.id);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile\": \"+919999999999\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Authenticates a user via mobile number. If the user does not exist, they are signed up. If their number is listed in ADMIN_MOBILES in the backend's `.env`, they will be automatically registered/promoted to `admin` with `active` status. Otherwise, they are created as a `student` with `pending` status. Generates and returns both an `accessToken` and a `refreshToken`."
          },
          "response": []
        },
        {
          "name": "Refresh Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"New access token is returned and stored\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property(\"accessToken\");",
                  "    if (response.accessToken) {",
                  "        pm.collectionVariables.set(\"accessToken\", response.accessToken);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh-token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "refresh-token"
              ]
            },
            "description": "Obtain a new `accessToken` using a valid `refreshToken`."
          },
          "response": []
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Logged out successfully\", function () {",
                  "    pm.expect(pm.response.json().message).to.equal(\"Logged out\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{studentUserId}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            },
            "description": "Logs out a user and invalidates their refresh token in the database."
          },
          "response": []
        }
      ]
    },
